# Database Configuration
# Leave empty to use ${pictoria_dir}/pictoria.duckdb (recommended).
# Override only when pointing at an alternate path.
DB_PATH=

# DuckDB runtime tuning
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4

# Slow Query Logging Configuration
# Set the threshold in milliseconds for what is considered a slow query
# Default: 100ms
SLOW_QUERY_THRESHOLD_MS=100